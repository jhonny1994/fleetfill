NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SITE_URL=https://admin.example.com

# The deployed public origin is a runtime contract, not a hosting-provider identity.
# Configure this per environment on whichever host is active.

# Local development example:
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-supabase-anon-key
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
#
# Playwright/CI uses a separate local harness host:
# NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3005
