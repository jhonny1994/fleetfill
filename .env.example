APP_ENV=production
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# App runtime flags.
CRASH_REPORTING_ENABLED=false
GOOGLE_AUTH_ENABLED=true
MAINTENANCE_MODE=false
FORCE_UPDATE_REQUIRED=false

# User-facing app contact settings.
SUPPORT_EMAIL=support@example.com
SUPPORT_EMAIL_TO=support@example.com

# Optional client-side Firebase app overrides.
# Standard production/mobile builds should normally use native Firebase config
# files (`google-services.json` / `GoogleService-Info.plist`) supplied outside git.
# Only set these if you intentionally override the native config at runtime.
# FIREBASE_API_KEY=your-firebase-api-key
# FIREBASE_MESSAGING_SENDER_ID=your-firebase-sender-id
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
# FIREBASE_ANDROID_APP_ID=your-firebase-android-app-id
# FIREBASE_IOS_APP_ID=your-firebase-ios-app-id

# Server-side push worker settings.
PUSH_NOTIFICATIONS_ENABLED=true
PUSH_NOTIFICATIONS_PROVIDER=fcm_v1
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-firebase-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-...@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/..."}

# Transactional email worker settings.
TRANSACTIONAL_EMAIL_PROVIDER=your-provider-name
TRANSACTIONAL_EMAIL_PROVIDER_ENDPOINT=https://api.your-email-provider.example/send
TRANSACTIONAL_EMAIL_PROVIDER_API_KEY=your-provider-api-key
TRANSACTIONAL_EMAIL_PROVIDER_WEBHOOK_SECRET=your-provider-webhook-secret

# Auth provider settings.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-google-web-client-id
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=your-google-client-secret
